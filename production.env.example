# =====================================================================
# JHoraAI Professional Production Environment Variables Template
# =====================================================================
# Copy this file to help you set up your environment variables in the 
# Cloudflare Pages Dashboard under Settings -> Environment Variables.
# All variable names are prefixed with 'VITE_' to allow them to be safely
# compiled into the client bundle at build-time.

# 1. Firebase Authentication & Google Sign-In Configurations
VITE_FIREBASE_API_KEY="AIzaSyYourProductionFirebaseApiKeyHere"
VITE_FIREBASE_AUTH_DOMAIN="jhora-ai-professional.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="jhora-ai-professional"
VITE_FIREBASE_STORAGE_BUCKET="jhora-ai-professional.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789012"
VITE_FIREBASE_APP_ID="1:123456789012:web:abcdef1234567890"

# 2. JHoraAI Production API Calculation Engine
# This is the HTTPS endpoint pointing to your self-hosted JHoraAI / VedicAstro
# backend service. Do not include a trailing slash.
VITE_JHORA_API_URL="https://api.jhoraai-professional.com"
