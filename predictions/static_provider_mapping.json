  "mapping_types": [
    "Name Mapping",
    "Identifier Mapping",
    "Enum Mapping",
    "Calculation Mapping",
    "Coordinate Mapping",
    "Normalization Rule",
    "Unit Conversion"
  ],

  "coordinate_systems": [
    "Sidereal",
    "Tropical"
  ],

  "angle_units": [
    "Degrees",
    "Degrees Minutes Seconds",
    "Decimal Degrees"
  ],

  "normalization_rules": [
    "Canonical Planet Names",
    "Canonical Sign Names",
    "Canonical House Numbers",
    "Canonical Nakshatra Names",
    "Canonical Dasha Names",
    "Canonical Yoga Names",
    "Canonical Dosha Names"
