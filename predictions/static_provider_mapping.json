  "dependencies": [
    "static_core.json",
    "static_planets.json",
    "static_signs.json",
    "static_houses.json",
    "static_nakshatras.json",
    "static_divisional_charts.json",
    "static_dashas.json",
    "static_yogas.json",
    "static_doshas.json"
