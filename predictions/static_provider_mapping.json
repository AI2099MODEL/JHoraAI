{
  "schema": {
    "name": "Static Provider Mapping",
    "version": "1.0.0",
    "description": "Canonical mapping between external astrology providers and the internal JHora AI Professional data model."
  },

  "canonical_provider": {
    "id": "JHORA_NATIVE",
    "name": "JHora AI Professional",
    "role": "Internal Canonical Model"
  },

  "supported_providers": [
    {
      "id": "JHORA",
      "name": "Jagannatha Hora",
      "type": "Desktop Software"
    },
    {
      "id": "JHORA_API",
      "name": "Jagannatha Hora API",
      "type": "REST API"
    },
    {
      "id": "ASTROKAYA",
      "name": "Astrokaya",
      "type": "Web API"
    },
    {
      "id": "SWISS_EPHEMERIS",
      "name": "Swiss Ephemeris",
      "type": "Astronomical Library"
    },
    {
      "id": "FLATLIB",
      "name": "Flatlib",
      "type": "Python Library"
    },
    {
      "id": "CUSTOM_ENGINE",
      "name": "JHora AI Engine",
      "type": "Internal Engine"
    }
  ],

  "supported_entities": [
    "Planet",
    "House",
    "Sign",
    "Nakshatra",
    "Pada",
    "House Cusp",
    "Planet Strength",
    "Yoga",
    "Dosha",
